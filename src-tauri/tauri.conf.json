{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WhatsApp",
  "identifier": "com.whatsapp.unofficial",
  "version": "1.0.0",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "security": {
      "csp": "default-src 'self' https://web.whatsapp.com https://*.whatsapp.net wss://*.whatsapp.net; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; media-src *; connect-src *"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "WhatsApp Desktop for Linux",
    "longDescription": "Official WhatsApp Web wrapped in a native Linux desktop app with system tray, notifications, and audio support.",
    "category": "SocialNetworking",
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libssl3", "libayatana-appindicator3-1", "gstreamer1.0-pipewire"]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  }
}
